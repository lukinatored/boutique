{% extends 'base.html.twig' %}

{% block title %}Montres personnalisées - WatchShop{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-crown text-warning"></i> Créations WatchShop</h1>
        {% if app.user %}
            <a href="{{ path('app_montre_perso_creer') }}" class="btn btn-primary">
                <i class="fas fa-plus"></i> Créer ma montre
            </a>
        {% endif %}
    </div>

    <p class="text-muted mb-4">Découvrez les montres uniques créées par notre communauté</p>

    {% if montres|length > 0 %}
        <div class="row">
            {% for montre in montres %}
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div style="height:220px;overflow:hidden;background:#f5f3ed;display:flex;align-items:center;justify-content:center;">
                            {% if montre.image %}
                                <img src="/uploads/montres_perso/{{ montre.image }}" alt="{{ montre.nom }}" style="width:100%;height:100%;object-fit:cover;">
                            {% else %}
                                <i class="fas fa-clock fa-5x text-muted"></i>
                            {% endif %}
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">{{ montre.nom }}</h5>
                            <p class="price">{{ montre.prix|number_format(2, ',', ' ') }} €</p>
                            <div class="mb-2">
                                <span class="badge bg-secondary">{{ montre.boitier }}</span>
                                <span class="badge bg-secondary">{{ montre.bracelet }}</span>
                            </div>
                            <p><small class="text-muted">👤 {{ montre.createur.prenom }} {{ montre.createur.nom|slice(0,1) }}.</small></p>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a href="{{ path('app_montre_perso_detail', {'id': montre.id}) }}" class="btn btn-primary w-100">Voir la création</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-5">
            <i class="fas fa-crown fa-4x text-muted mb-3"></i>
            <p class="lead">Aucune création pour le moment</p>
            {% if app.user %}
                <a href="{{ path('app_montre_perso_creer') }}" class="btn btn-primary">Créer ma montre</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn btn-primary">Connectez-vous pour créer</a>
            {% endif %}
        </div>
    {% endif %}
</div>
{% endblock %}
