{% extends 'base.html.twig' %}

{% block title %}Paiement à la livraison - WatchShop{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0"><i class="fas fa-truck"></i> Paiement à la livraison</h4>
                </div>
                <div class="card-body">
                    <!-- Récapitulatif rapide -->
                    <div class="alert alert-light">
                        <h6>🛒 Récapitulatif de votre commande</h6>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Produit</th>
                                        <th>Qté</th>
                                        <th>Prix</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for item in items %}
                                        <tr>
                                            <td>{{ item.produit.nom }}</td>
                                            <td>{{ item.quantite }}</td>
                                            <td>{{ item.sousTotal|number_format(2, ',', ' ') }} €</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                                <tfoot>
                                    <tr class="table-dark">
                                        <td colspan="2" class="text-end"><strong>Total</strong></td>
                                        <td><strong>{{ total|number_format(2, ',', ' ') }} €</strong></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>

                    <!-- Formulaire code promo -->
                    <div class="card mb-3">
                        <div class="card-body">
                            <h6>🎁 Code promo</h6>
                            <form method="post" action="{{ path('app_paiement_livraison_form') }}" class="d-flex gap-2">
                                <input type="text" name="code_promo" class="form-control" placeholder="Entrez votre code promo" value="{{ app.request.get('code_promo') }}">
                                <button type="submit" class="btn btn-warning">Appliquer</button>
                            </form>
                            {% if code_promo_applique %}
                                <div class="alert alert-success mt-2">
                                    ✅ Code <strong>{{ code_promo_applique.code }}</strong> appliqué ({{ code_promo_applique.reduction|number_format(2, ',', ' ') }} € de réduction)
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    <!-- Formulaire adresse -->
                    {{ form_start(form) }}
                        {{ form_errors(form) }}
                        
                        <h6>📍 Adresse de livraison</h6>
                        <div class="mb-3">
                            {{ form_label(form.adresse) }}
                            {{ form_widget(form.adresse, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.adresse) }}
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                {{ form_label(form.codePostal) }}
                                {{ form_widget(form.codePostal, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.codePostal) }}
                            </div>
                            <div class="col-md-8 mb-3">
                                {{ form_label(form.ville) }}
                                {{ form_widget(form.ville, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.ville) }}
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.departement) }}
                                {{ form_widget(form.departement, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.departement) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.region) }}
                                {{ form_widget(form.region, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.region) }}
                            </div>
                        </div>

                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> 
                            Vous paierez à la livraison en espèces ou par carte bancaire.
                        </div>

                        {{ form_row(form._token) }}
                        <button type="submit" class="btn btn-success w-100">
                            <i class="fas fa-check"></i> Valider la livraison
                        </button>
                    {{ form_end(form) }}

                    <div class="mt-3">
                        <a href="{{ path('app_cart') }}" class="btn btn-secondary btn-sm">
                            <i class="fas fa-arrow-left"></i> Retour au panier
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
