{% extends 'base.html.twig' %}

{% block title %}{{ article.titre }} - WatchShop{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body p-4">
                    <div class="mb-3">
                        <span class="badge bg-primary">{{ article.categorie }}</span>
                        <small class="text-muted ms-2">{{ article.createdAt|date('d/m/Y H:i') }}</small>
                        <span class="badge bg-secondary float-end"><i class="fas fa-eye"></i> {{ article.vue }}</span>
                    </div>
                    <h1 class="mb-4">{{ article.titre }}</h1>
                    <div class="article-content">
                        {{ article.contenu|nl2br }}
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <a href="{{ path('app_blog') }}" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Retour au blog
                        </a>
                        <a href="{{ path('app_produits') }}" class="btn btn-custom">
                            <i class="fas fa-shopping-cart"></i> Voir nos montres
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
