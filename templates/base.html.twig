<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}WatchShop - Montres de Luxe{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #1a1a2e;
            --secondary: #e94560;
            --gold: #ffd700;
            --dark: #0f3460;
            --shadow: 0 15px 35px rgba(0,0,0,0.1);
        }
        body { font-family: 'Poppins', sans-serif; background: #f8f9fa; padding-top: 76px; }
        .navbar { background: rgba(26,26,46,0.95) !important; backdrop-filter: blur(10px); box-shadow: 0 2px 20px rgba(0,0,0,0.1); position: fixed; top: 0; width: 100%; z-index: 1000; }
        .navbar-brand { font-size: 1.8rem; font-weight: 700; background: linear-gradient(135deg, #fff, var(--gold)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .nav-link { font-weight: 500; transition: all 0.3s; }
        .nav-link:hover { color: var(--gold) !important; transform: translateY(-2px); }
        .product-card { background: white; border-radius: 15px; overflow: hidden; transition: all 0.4s; box-shadow: var(--shadow); margin-bottom: 25px; }
        .product-card:hover { transform: translateY(-10px); box-shadow: 0 25px 45px rgba(0,0,0,0.15); }
        .product-img { height: 250px; object-fit: cover; width: 100%; transition: transform 0.6s; }
        .product-card:hover .product-img { transform: scale(1.1); }
        .price { font-size: 1.4rem; font-weight: 700; color: var(--secondary); }
        .btn-custom { background: linear-gradient(135deg, var(--primary), var(--dark)); border: none; border-radius: 25px; padding: 10px 25px; transition: all 0.3s; }
        .btn-custom:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(26,26,46,0.3); }
        .footer { background: var(--primary); color: white; padding: 50px 0 20px; margin-top: 50px; }
        .social-links a { color: white; margin: 0 10px; font-size: 1.2rem; transition: all 0.3s; }
        .social-links a:hover { color: var(--gold); transform: translateY(-3px); }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        .fade-in { animation: fadeInUp 0.6s ease forwards; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}"><i class="fas fa-clock"></i> WatchShop</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto me-4">
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}"><i class="fas fa-home"></i> Accueil</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_produits') }}"><i class="fas fa-clock"></i> Collection</a></li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_cart') }}"><i class="fas fa-shopping-cart"></i> <span class="cart-count badge bg-danger rounded-pill" id="cartCount">0</span></a></li>
                    {% if app.user %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="fas fa-user"></i> {{ app.user.prenom }}</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="{{ path('app_account') }}">Mon compte</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="{{ path('app_logout') }}">Déconnexion</a></li>
                            </ul>
                        </li>
                    {% else %}
                        <li class="nav-item"><a class="nav-link" href="{{ path('app_login') }}"><i class="fas fa-lock"></i> Connexion</a></li>
                        <li class="nav-item"><a class="nav-link" href="{{ path('app_register') }}"><i class="fas fa-user-plus"></i> Inscription</a></li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>

    <main>
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show m-3">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        {% endfor %}
        {% block body %}{% endblock %}
    </main>

    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5><i class="fas fa-clock"></i> WatchShop</h5>
                    <p>La référence de la montre de luxe depuis 2024. Qualité et élégance pour tous nos produits.</p>
                </div>
                <div class="col-md-4 mb-4">
                    <h5>Liens rapides</h5>
                    <ul class="list-unstyled">
                        <li><a href="{{ path('app_home') }}">Accueil</a></li>
                        <li><a href="{{ path('app_produits') }}">Collection</a></li>
                        <li><a href="#">CGV</a></li>
                        <li><a href="#">Contact</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-4">
                    <h5>Suivez-nous</h5>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>
            <hr class="mt-3">
            <div class="text-center">
                <p class="mb-0">&copy; 2024 WatchShop - Tous droits réservés</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Mettre à jour le compteur du panier
        function updateCartCount() {
            fetch('/panier/count')
                .then(response => response.json())
                .then(data => {
                    document.getElementById('cartCount').innerText = data.count;
                })
                .catch(() => {});
        }
        updateCartCount();
    </script>
    {% block javascripts %}{% endblock %}
</body>
</html>
