{% extends 'base.html.twig' %}

{% block title %}{{ montre.nom }} - WatchShop{% endblock %}

{% block stylesheets %}
<style>
    .gallery-main {
        background: #f8f8f8;
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        min-height: 300px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #eee;
        position: relative;
        margin-bottom: 15px;
    }
    .gallery-main img {
        max-width: 100%;
        max-height: 350px;
        object-fit: contain;
    }
    .gallery-thumbnails {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: center;
    }
    .gallery-thumbnails .thumb {
        width: 70px;
        height: 70px;
        border-radius: 10px;
        overflow: hidden;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all 0.3s ease;
        background: #f5f3ed;
    }
    .gallery-thumbnails .thumb:hover {
        border-color: #c9a84c;
        transform: scale(1.05);
    }
    .gallery-thumbnails .thumb.active {
        border-color: #c9a84c;
        box-shadow: 0 0 20px rgba(201,168,76,0.3);
    }
    .gallery-thumbnails .thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .gallery-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255,255,255,0.9);
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        cursor: pointer;
        box-shadow: 0 3px 15px rgba(0,0,0,0.1);
        transition: all 0.3s;
        font-size: 1.2rem;
        color: #333;
    }
    .gallery-nav:hover {
        background: #c9a84c;
        color: white;
    }
    .gallery-nav.prev { left: 10px; }
    .gallery-nav.next { right: 10px; }
    .gallery-nav.hidden { display: none; }
</style>
{% endblock %}

{% block body %}
<div class="container py-4">
    <nav style="font-size:0.85rem;color:#888;margin-bottom:20px;">
        <a href="{{ path('app_home') }}" style="color:#0066c0;text-decoration:none;">Accueil</a>
        <span style="margin:0 6px;color:#ccc;">›</span>
        <a href="{{ path('app_montre_perso') }}" style="color:#0066c0;text-decoration:none;">Créations</a>
        <span style="margin:0 6px;color:#ccc;">›</span>
        <span style="color:#333;">{{ montre.nom }}</span>
    </nav>

    <div class="row">
        <div class="col-md-6">
            <div class="gallery-main" id="galleryMain">
                {% if montre.image %}
                    <img src="/uploads/montres_perso/{{ montre.image }}" alt="{{ montre.nom }}" id="mainImage">
                {% else %}
                    <img src="https://picsum.photos/seed/{{ montre.id }}/600/600" alt="{{ montre.nom }}" id="mainImage">
                {% endif %}
            </div>

            <div class="gallery-thumbnails" id="thumbnails">
                <div class="thumb active">
                    <img src="/uploads/montres_perso/{{ montre.image ?: 'default.jpg' }}" alt="Vue 1" onclick="changeImage(this, '/uploads/montres_perso/{{ montre.image ?: 'default.jpg' }}')">
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <span style="background:#f0f7ff;color:#0066c0;padding:3px 14px;border-radius:12px;font-size:0.8rem;display:inline-block;margin-bottom:8px;">
                <i class="fas fa-tag"></i> Création personnalisée
            </span>

            <h1 style="font-size:2rem;font-weight:700;color:#0f1111;margin-bottom:8px;">{{ montre.nom }}</h1>

            <div style="background:#f7f7f7;padding:14px 18px;border-radius:12px;margin:12px 0;">
                <span style="font-size:2rem;font-weight:700;color:#b12704;">{{ montre.prix|number_format(2, ',', ' ') }} €</span>
            </div>

            <div style="margin:12px 0;padding:12px 0;border-top:1px solid #eee;">
                <p style="color:#333;line-height:1.6;">{{ montre.description }}</p>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px 16px;padding:12px 16px;background:#fafafa;border-radius:12px;border:1px solid #eee;margin:14px 0;">
                <div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #f0f0f0;">
                    <span style="color:#888;font-size:0.85rem;">Boîtier</span>
                    <span style="font-weight:500;color:#0f1111;font-size:0.85rem;">{{ montre.boitier }}</span>
                </div>
                <div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #f0f0f0;">
                    <span style="color:#888;font-size:0.85rem;">Bracelet</span>
                    <span style="font-weight:500;color:#0f1111;font-size:0.85rem;">{{ montre.bracelet }}</span>
                </div>
                <div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #f0f0f0;">
                    <span style="color:#888;font-size:0.85rem;">Mouvement</span>
                    <span style="font-weight:500;color:#0f1111;font-size:0.85rem;">{{ montre.mouvement }}</span>
                </div>
                <div style="display:flex;justify-content:space-between;padding:4px 0;">
                    <span style="color:#888;font-size:0.85rem;">Créateur</span>
                    <span style="font-weight:500;color:#0f1111;font-size:0.85rem;">{{ montre.createur.prenom }} {{ montre.createur.nom|slice(0,1) }}.</span>
                </div>
            </div>

            {% if montre.source %}
                <p><strong>Source :</strong> <a href="{{ montre.source }}" target="_blank" style="color:#0066c0;">{{ montre.source }}</a></p>
            {% endif %}

            <div style="display:flex;gap:10px;margin:16px 0;">
                <a href="{{ path('app_montre_perso_achat_ajouter', {'id': montre.id}) }}" style="flex:1;background:#ffd814;border:none;border-radius:24px;padding:12px 24px;font-weight:600;font-size:1rem;color:#0f1111;text-align:center;text-decoration:none;display:inline-flex;align-items:center;justify-content:center;gap:8px;transition:background 0.2s;">
                    <i class="fas fa-shopping-bag"></i> Acheter
                </a>
                <a href="{{ path('app_wishlist_add', {'id': montre.id}) }}" style="width:50px;height:50px;border-radius:50%;border:1px solid #ddd;background:#fff;color:#555;display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:1.2rem;flex-shrink:0;transition:all 0.2s;">
                    <i class="fas fa-heart"></i>
                </a>
            </div>

            <div style="display:flex;gap:10px;flex-wrap:wrap;">
                <a href="{{ path('app_montre_perso') }}" style="color:#0066c0;text-decoration:none;font-size:0.85rem;display:inline-flex;align-items:center;gap:6px;">
                    <i class="fas fa-arrow-left"></i> Retour aux créations
                </a>
                <a href="{{ path('app_createur_vitrine', {'id': montre.createur.id}) }}" style="color:#0066c0;text-decoration:none;font-size:0.85rem;display:inline-flex;align-items:center;gap:6px;">
                    👤 Voir la vitrine du créateur
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    function changeImage(el, src) {
        document.getElementById('mainImage').src = src;
        document.querySelectorAll('.gallery-thumbnails .thumb').forEach(t => t.classList.remove('active'));
        el.closest('.thumb').classList.add('active');
    }
</script>
{% endblock %}
