{% extends 'base.html.twig' %}

{% block title %}Dashboard Créateur - WatchShop{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>🎨 Mon espace créateur</h1>
        <a href="{{ path('app_montre_perso_creer') }}" class="btn btn-primary">+ Nouvelle création</a>
    </div>

    <!-- Statistiques -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h3>{{ montres|length }}</h3>
                    <p class="text-muted">Total créations</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h3>{{ publiees }}</h3>
                    <p class="text-muted">Publiées</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h3>{{ enAttente }}</h3>
                    <p class="text-muted">En attente</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h3>{{ totalVues }}</h3>
                    <p class="text-muted">Vues totales</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Liste des créations -->
    <div class="card">
        <div class="card-body">
            <h5>Mes créations</h5>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Montre</th>
                            <th>Prix</th>
                            <th>Statut</th>
                            <th>Vues</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for montre in montres %}
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        {% if montre.image %}
                                            <img src="/uploads/montres_perso/{{ montre.image }}" alt="{{ montre.nom }}" style="width:40px;height:40px;object-fit:cover;border-radius:5px;">
                                        {% else %}
                                            <i class="fas fa-clock fa-2x text-muted"></i>
                                        {% endif %}
                                        {{ montre.nom }}
                                    </div>
                                </td>
                                <td>{{ montre.prix|number_format(2, ',', ' ') }} €</td>
                                <td>
                                    {% if montre.estPubliee %}
                                        <span class="badge bg-success">✅ Publiée</span>
                                    {% else %}
                                        <span class="badge bg-warning text-dark">⏳ En attente</span>
                                    {% endif %}
                                </td>
                                <td>{{ montre.nbVues }}</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="{{ path('app_montre_perso_detail', {'id': montre.id}) }}" class="btn btn-primary">Voir</a>
                                        {% if not montre.estPubliee %}
                                            <a href="{{ path('app_montre_perso_publier', {'id': montre.id}) }}" class="btn btn-success">Publier</a>
                                        {% endif %}
                                        <a href="{{ path('app_montre_perso_supprimer', {'id': montre.id}) }}" class="btn btn-danger" onclick="return confirm('Supprimer ?')">X</a>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-3 text-muted">
                                    <p>Vous n'avez pas encore de création</p>
                                    <a href="{{ path('app_montre_perso_creer') }}" class="btn btn-primary btn-sm">Créer ma première montre</a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a href="{{ path('app_account') }}" class="btn btn-secondary">← Retour</a>
    </div>
</div>
{% endblock %}
