<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Facture {{ facture.numero }}</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; color: #333; }
        .header { text-align: center; border-bottom: 3px solid #c9a84c; padding-bottom: 20px; }
        .logo { font-size: 28px; font-weight: bold; color: #1a1a2e; }
        .logo span { color: #c9a84c; }
        .infos { margin: 30px 0; display: flex; justify-content: space-between; }
        .infos-left { width: 50%; }
        .infos-right { width: 50%; text-align: right; }
        table { width: 100%; border-collapse: collapse; margin: 20px 0; }
        th { background: #1a1a2e; color: white; padding: 12px; text-align: left; }
        td { padding: 10px; border-bottom: 1px solid #ddd; }
        .total { text-align: right; margin-top: 30px; }
        .total-line { display: flex; justify-content: flex-end; padding: 8px 0; }
        .total-line .label { width: 200px; font-weight: 500; }
        .total-line .value { width: 150px; text-align: right; font-weight: 500; }
        .grand-total { font-size: 18px; font-weight: bold; color: #e94560; border-top: 2px solid #e94560; padding-top: 10px; }
        .footer { text-align: center; margin-top: 50px; color: #888; font-size: 12px; border-top: 1px solid #ddd; padding-top: 20px; }
        .badge { background: #28a745; color: white; padding: 5px 15px; border-radius: 20px; display: inline-block; }
        .badge-warning { background: #ffc107; color: #000; }
    </style>
</head>
<body>
    <div class="header">
        <div class="logo">⌚ Watch<span>Shop</span></div>
        <p>Facture officielle</p>
    </div>

    <div class="infos">
        <div class="infos-left">
            <h3>Facturé à :</h3>
            <p><strong>{{ facture.client.prenom }} {{ facture.client.nom }}</strong></p>
            <p>{{ facture.client.adresse }}</p>
            <p>{{ facture.client.email }}</p>
        </div>
        <div class="infos-right">
            <h3>Détails de la facture</h3>
            <p><strong>N° Facture :</strong> {{ facture.numero }}</p>
            <p><strong>Date :</strong> {{ facture.createdAt|date('d/m/Y') }}</p>
            <p><strong>Statut :</strong> 
                <span class="badge {% if facture.statut == 'payee' %}badge{% else %}badge-warning{% endif %}">
                    {{ facture.statut|capitalize }}
                </span>
            </p>
            <p><strong>Commande :</strong> #{{ facture.commande.id }}</p>
        </div>
    </div>

    <h3>Détails de la commande</h3>
    <table>
        <thead>
            <tr>
                <th>Produit</th>
                <th>Quantité</th>
                <th>Prix unitaire</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            {% for detail in facture.commande.details %}
                <tr>
                    <td>
                        {% if detail.produit %}
                            {{ detail.produit.nom }}
                        {% else %}
                            Montre personnalisée
                        {% endif %}
                    </td>
                    <td>{{ detail.quantite }}</td>
                    <td>{{ detail.prix|number_format(2, ',', ' ') }} €</td>
                    <td>{{ (detail.prix * detail.quantite)|number_format(2, ',', ' ') }} €</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="total">
        <div class="total-line">
            <span class="label">Sous-total</span>
            <span class="value">{{ facture.total|number_format(2, ',', ' ') }} €</span>
        </div>
        <div class="total-line">
            <span class="label">TVA (20%)</span>
            <span class="value">{{ facture.tva|number_format(2, ',', ' ') }} €</span>
        </div>
        <div class="total-line grand-total">
            <span class="label">Total TTC</span>
            <span class="value">{{ facture.totalTTC|number_format(2, ',', ' ') }} €</span>
        </div>
    </div>

    <div class="footer">
        <p>WatchShop - 75001 Paris, France - Tél: +33 1 23 45 67 89</p>
        <p>Merci pour votre confiance !</p>
    </div>
</body>
</html>
