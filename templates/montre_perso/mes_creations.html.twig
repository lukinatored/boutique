{% extends 'base.html.twig' %}

{% block title %}Mes créations - WatchShop{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-crown text-warning"></i> Mes créations</h1>
        <a href="{{ path('app_montre_perso_creer') }}" class="btn btn-primary">
            <i class="fas fa-plus"></i> Créer une montre
        </a>
    </div>

    {% if montres|length > 0 %}
        <div class="row">
            {% for montre in montres %}
                <div class="col-md-4 mb-4">
                    <div class="card product-card h-100">
                        <div style="height: 200px; overflow: hidden; background: linear-gradient(135deg, #1a1a2e, #16213e); display: flex; align-items: center; justify-content: center; color: white; flex-direction: column;">
                            {% if montre.image %}
                                <img src="/uploads/montres_perso/{{ montre.image }}" alt="{{ montre.nom }}" style="width: 100%; height: 100%; object-fit: cover;">
                            {% else %}
                                <i class="fas fa-clock fa-4x mb-2" style="color: #c9a84c;"></i>
                                <span style="font-size: 12px; opacity: 0.7;">{{ montre.nom }}</span>
                            {% endif %}
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">{{ montre.nom }}</h5>
                            <p class="price">{{ montre.prix|number_format(2, ',', ' ') }} €</p>
                            <p>
                                {% if montre.estPubliee %}
                                    <span class="badge bg-success">Publiée</span>
                                {% else %}
                                    <span class="badge bg-warning text-dark">En attente</span>
                                {% endif %}
                            </p>
                            <div class="d-grid gap-2">
                                <a href="{{ path('app_montre_perso_detail', {'id': montre.id}) }}" class="btn btn-primary">Voir</a>
                                {% if not montre.estPubliee %}
                                    <a href="{{ path('app_montre_perso_publier', {'id': montre.id}) }}" class="btn btn-success">Publier</a>
                                {% endif %}
                                <a href="{{ path('app_montre_perso_supprimer', {'id': montre.id}) }}" class="btn btn-danger" onclick="return confirm('Supprimer cette montre ?')">Supprimer</a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-5">
            <i class="fas fa-crown fa-4x text-muted mb-3"></i>
            <p class="lead">Vous n'avez pas encore créé de montre</p>
            <a href="{{ path('app_montre_perso_creer') }}" class="btn btn-primary">Créer ma première montre</a>
        </div>
    {% endif %}
</div>
{% endblock %}
