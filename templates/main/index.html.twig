{% extends 'base.html.twig' %}

{% block title %}Accueil - WatchShop{% endblock %}

{% block body %}
<div class="container">
    <!-- HERO -->
    <div style="background:linear-gradient(135deg,#0a0a1a,#1a1a2e 50%,#0f3460);padding:70px 0 50px;text-align:center;border-radius:16px;margin-bottom:40px;color:#fff;">
        <h1 style="font-size:3.2rem;font-weight:700;">L'élégance <span style="background:linear-gradient(135deg,#c9a84c,#f0d060);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">à portée</span> de main</h1>
        <p style="color:rgba(255,255,255,0.5);max-width:480px;margin:12px auto 24px;font-size:1.05rem;">Découvrez notre collection de montres de luxe.</p>
        <a href="{{ path('app_produits') }}" style="background:linear-gradient(135deg,#c9a84c,#b8942e);color:#fff;padding:12px 40px;border-radius:50px;text-decoration:none;font-weight:600;display:inline-block;box-shadow:0 8px 30px rgba(201,168,76,0.25);">Explorer</a>
    </div>

    <h2 style="font-size:2rem;font-weight:700;text-align:center;color:#1a1a2e;">Nos dernières montres</h2>
    <div style="width:50px;height:3px;background:#c9a84c;margin:10px auto 28px;border-radius:2px;"></div>

    <div class="row">
        {% for p in produits %}
            <div class="col-md-3 col-6 mb-4">
                <div style="background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 4px 16px rgba(0,0,0,0.04);height:100%;">
                    <div style="height:210px;overflow:hidden;background:#f5f3ed;display:flex;align-items:center;justify-content:center;">
                        <img src="/uploads/produits/{{ p.image ?: 'default.jpg' }}" alt="{{ p.nom }}" style="width:100%;height:100%;object-fit:cover;">
                    </div>
                    <div style="padding:14px 16px 16px;">
                        <div style="font-size:0.95rem;font-weight:600;color:#0f1111;">{{ p.nom }}</div>
                        <div style="font-size:1.15rem;font-weight:700;color:#b12704;">{{ p.prix|number_format(2, ',', ' ') }} €</div>
                        <a href="{{ path('app_produit_detail', {'id': p.id}) }}" style="color:#0066c0;font-size:0.8rem;text-decoration:none;">Voir détails →</a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center"><p>Aucun produit</p></div>
        {% endfor %}
    </div>
</div>
{% endblock %}
