{% extends 'base.html.twig' %}

{% block title %}Blog - WatchShop{% endblock %}

{% block body %}
<div class="container py-4">
    <h1 class="text-center mb-4"><i class="fas fa-blog text-primary"></i> Blog WatchShop</h1>
    <p class="text-center text-muted mb-5">Découvrez nos articles sur les montres, les tendances et les conseils</p>

    <div class="row">
        {% for article in articles %}
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <span class="badge bg-primary mb-2">{{ article.categorie }}</span>
                        <h5 class="card-title">{{ article.titre }}</h5>
                        <p class="card-text">{{ article.resume|slice(0, 120) }}...</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">{{ article.createdAt|date('d/m/Y') }}</small>
                            <a href="{{ path('app_blog_article', {'id': article.id}) }}" class="btn btn-custom btn-sm">Lire</a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center">
                <p>Aucun article pour le moment</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
