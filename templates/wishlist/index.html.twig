{% extends 'base.html.twig' %}

{% block title %}Ma wishlist - WatchShop{% endblock %}

{% block body %}
<div class="container py-4">
    <h1 class="mb-4"><i class="fas fa-heart text-danger"></i> Ma wishlist</h1>

    {% if wishlist|length > 0 %}
        <div class="row">
            {% for item in wishlist %}
                <div class="col-md-3 mb-4">
                    <div class="card product-card h-100">
                        <div style="height: 150px; overflow: hidden; background: #f0f0f0; display: flex; align-items: center; justify-content: center;">
                            <img src="https://picsum.photos/seed/{{ item.produit.id }}/300/300" 
                                 alt="{{ item.produit.nom }}" 
                                 style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">{{ item.produit.nom }}</h5>
                            <p class="price">{{ item.produit.prix|number_format(2, ',', ' ') }} €</p>
                            <a href="{{ path('app_produit_detail', {'id': item.produit.id}) }}" class="btn btn-primary w-100 mb-2">Voir</a>
                            <a href="{{ path('app_wishlist_remove', {'id': item.produit.id}) }}" class="btn btn-danger w-100">Retirer</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-5">
            <i class="fas fa-heart fa-4x text-muted mb-3"></i>
            <p class="lead">Votre wishlist est vide</p>
            <a href="{{ path('app_produits') }}" class="btn btn-primary">Découvrir nos produits</a>
        </div>
    {% endif %}
</div>
{% endblock %}
