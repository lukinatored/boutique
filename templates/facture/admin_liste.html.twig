{% extends 'base.html.twig' %}

{% block title %}Gestion des factures - Admin{% endblock %}

{% block body %}
<div class="container py-4">
    <h1 class="mb-4"><i class="fas fa-file-invoice text-primary"></i> Gestion des factures</h1>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>N° Facture</th>
                            <th>Client</th>
                            <th>Commande</th>
                            <th>Total TTC</th>
                            <th>Statut</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for facture in factures %}
                            <tr>
                                <td><strong>{{ facture.numero }}</strong></td>
                                <td>{{ facture.client.prenom }} {{ facture.client.nom }}</td>
                                <td>#{{ facture.commande.id }}</td>
                                <td>{{ facture.totalTTC|number_format(2, ',', ' ') }} €</td>
                                <td>
                                    <span class="badge {% if facture.statut == 'payee' %}bg-success{% else %}bg-warning text-dark{% endif %}">
                                        {{ facture.statut|capitalize }}
                                    </span>
                                </td>
                                <td>{{ facture.createdAt|date('d/m/Y') }}</td>
                                <td>
                                    <a href="{{ path('app_facture_pdf', {'id': facture.id}) }}" class="btn btn-sm btn-danger">
                                        <i class="fas fa-file-pdf"></i>
                                    </a>
                                    <a href="#" class="btn btn-sm btn-primary">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="7" class="text-center">Aucune facture</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
