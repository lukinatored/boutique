{% extends 'base.html.twig' %}

{% block title %}Mon compte - WatchShop{% endblock %}

{% block body %}
<h1 class="text-center mb-4">Mon compte</h1>
<div class="row">
    <div class="col-md-4">
        <div class="list-group">
            <a href="{{ path('app_account') }}" class="list-group-item list-group-item-action active">Mon profil</a>
            <a href="{{ path('app_logout') }}" class="list-group-item list-group-item-action text-danger">Déconnexion</a>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-dark text-white"><h4 class="mb-0">Mes informations</h4></div>
            <div class="card-body">
                <p><strong>Nom :</strong> {{ user.nom }}</p>
                <p><strong>Prénom :</strong> {{ user.prenom }}</p>
                <p><strong>Email :</strong> {{ user.email }}</p>
                <p><strong>Adresse :</strong> {{ user.adresse }}</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
