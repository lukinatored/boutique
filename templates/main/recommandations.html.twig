{% extends 'base.html.twig' %}

{% block title %}Recommandations - WatchShop{% endblock %}

{% block body %}
<div class="container py-4">
    <h2 class="text-center mb-4">🛍️ Recommandations</h2>
    <div class="row">
        {% for produit in produits %}
            <div class="col-md-3 mb-4">
                <div class="product-card">
                    <div class="product-img" style="height:200px;overflow:hidden;">
                        <img src="/uploads/produits/{{ produit.image ?: 'default.jpg' }}" alt="{{ produit.nom }}" style="width:100%;height:100%;object-fit:cover;">
                    </div>
                    <div class="product-body" style="padding:15px;">
                        <h5 style="font-size:0.95rem;">{{ produit.nom }}</h5>
                        <div style="font-size:1.1rem;font-weight:700;color:#b12704;">{{ produit.prix|number_format(2, ',', ' ') }} €</div>
                        <a href="{{ path('app_produit_detail', {'id': produit.id}) }}" class="btn btn-sm btn-custom w-100 mt-2">Voir</a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
